# Django
SECRET_KEY=replace-with-a-secure-secret
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Primary DB URL (used by backend if present)
DATABASE_URL=mysql+pymysql://servicelink_user:servicelink_password@db:3306/servicelink

# MySQL service variables (used by db container and Django fallback config)
MYSQL_DATABASE=servicelink
MYSQL_USER=servicelink_user
MYSQL_PASSWORD=servicelink_password
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_CONN_MAX_AGE=60

# CORS/CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIME_ZONE=Asia/Kolkata

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_AUTH_HEADER_TYPE=Bearer

# Frontend build-time API URL
VITE_API_BASE_URL=http://localhost:8000/api/
